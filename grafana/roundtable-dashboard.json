  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "query": {
          "query": "label_values(roundtable_calls_total{service_name=\"roundtable\"}, host_name)",
          "refId": "host"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "query": {
          "query": "label_values(roundtable_calls_total{service_name=\"roundtable\"}, project_name)",
          "refId": "project"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "role",
        "label": "Role",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "query": {
          "query": "label_values(roundtable_calls_total{service_name=\"roundtable\"}, roundtable_role)",
          "refId": "role"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
