      "type": "timeseries",
      "title": "Invocations by span_name",
      "description": "One line per span. roundtable.invoke = root; gemini/codex/claude = children. Not stacked because child spans are subsets of the root (stacking would double-count).",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (span_name) (rate(roundtable_calls_total{service_name=\"roundtable\", host_name=~\"$host\", project_name=~\"$project\", roundtable_role=~\"$role\"}[$__rate_interval]))",
          "legendFormat": "{{span_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "stacking": {
              "mode": "none",
              "group": "A"
