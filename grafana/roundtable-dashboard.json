    {
      "id": 1,
      "type": "stat",
      "title": "Total Invocations",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(roundtable_calls_total{service_name=\"roundtable\", span_name=\"roundtable.invoke\", host_name=~\"$host\", project_name=~\"$project\", roundtable_role=~\"$role\"}[$__range]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Success Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 5,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(roundtable_calls_total{service_name=\"roundtable\", span_name=\"roundtable.invoke\", status_code=\"STATUS_CODE_OK\", host_name=~\"$host\", project_name=~\"$project\", roundtable_role=~\"$role\"}[$__range])) / sum(increase(roundtable_calls_total{service_name=\"roundtable\", span_name=\"roundtable.invoke\", host_name=~\"$host\", project_name=~\"$project\", roundtable_role=~\"$role\"}[$__range])) * 100",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          },
          "noValue": "\u2014"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Invoke Duration",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 10,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(roundtable_duration_milliseconds_sum{service_name=\"roundtable\", span_name=\"roundtable.invoke\", host_name=~\"$host\", project_name=~\"$project\", roundtable_role=~\"$role\"}[$__range])) / clamp_min(sum(rate(roundtable_duration_milliseconds_count{service_name=\"roundtable\", span_name=\"roundtable.invoke\", host_name=~\"$host\", project_name=~\"$project\", roundtable_role=~\"$role\"}[$__range])), 1) / 1000",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1
        },
        "overrides": []
      }
    },
