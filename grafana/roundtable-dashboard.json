        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Role Distribution",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 24},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (roundtable_role) (increase(roundtable_calls_total{service_name=\"roundtable\", span_name=\"roundtable.invoke\"}[24h]))",
