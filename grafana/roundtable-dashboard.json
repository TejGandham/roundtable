      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 15},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(roundtable_duration_milliseconds_bucket{service_name=\"roundtable\", span_name=\"roundtable.codex\"}[1h])))",
