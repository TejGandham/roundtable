{
  "id": null,
  "uid": "roundtable-skill",
  "title": "Roundtable Skill",
  "tags": ["roundtable"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "30s", "1m", "5m", "15m"],
    "time_options": ["1h", "6h", "12h", "24h", "7d"]
  },
  "annotations": {
    "list": []
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Invocations",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(roundtable_calls_total{service_name=\"roundtable\", span_name=\"roundtable.invoke\"}[24h]))",
          "instant": true,
          "legendFormat": "Total"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Success Rate",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(roundtable_calls_total{service_name=\"roundtable\", span_name=\"roundtable.invoke\", status_code=\"STATUS_CODE_OK\"}[24h])) / sum(increase(roundtable_calls_total{service_name=\"roundtable\", span_name=\"roundtable.invoke\"}[24h])) * 100",
          "instant": true,
          "legendFormat": "Success %"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Duration",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(roundtable_duration_milliseconds_sum{service_name=\"roundtable\", span_name=\"roundtable.invoke\"}[1h])) / sum(rate(roundtable_duration_milliseconds_count{service_name=\"roundtable\", span_name=\"roundtable.invoke\"}[1h])) / 1000",
          "instant": true,
          "legendFormat": "Avg"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Gemini Status",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 6},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (roundtable_gemini_status) (increase(roundtable_calls_total{service_name=\"roundtable\", span_name=\"roundtable.invoke\"}[1h]))",
          "legendFormat": "{{roundtable_gemini_status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "fillOpacity": 35,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Codex Status",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 6},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (roundtable_codex_status) (increase(roundtable_calls_total{service_name=\"roundtable\", span_name=\"roundtable.invoke\"}[1h]))",
          "legendFormat": "{{roundtable_codex_status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
